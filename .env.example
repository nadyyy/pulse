# Copy this file to .env before running Prisma or the app.
# Example: cp .env.example .env

DATABASE_URL="postgresql://myapp:myapp@localhost:5432/myapp?schema=public"
# Optional direct connection URL for Prisma CLI operations.
DIRECT_URL="postgresql://myapp:myapp@localhost:5432/myapp?schema=public"
# Secret pepper for deterministic HMAC hashing (email hash, signed cart cookie, rate-limit keys).
AUTH_PEPPER="replace-with-a-long-random-secret"
# Password hashing cost factor (bcrypt). Increase gradually based on server capacity.
PASSWORD_HASH_COST="12"
# Optional (dev only by default): comma-separated emails to auto-promote as admin.
BOOTSTRAP_ADMIN_EMAILS=""
# Set true only if you intentionally want bootstrap admin auto-promotion in production.
ALLOW_BOOTSTRAP_ADMIN="false"
# Auth brute-force protections
AUTH_RATE_LIMIT_WINDOW_MS="600000"
AUTH_RATE_LIMIT_MAX_ATTEMPTS="8"
AUTH_RATE_LIMIT_BLOCK_MS="1800000"
# Optional demo seed password (should be changed immediately).
SEED_DEMO_PASSWORD="DemoPass#2026"
