# Copy this file to .env before running Prisma or the app.
# Example: cp .env.example .env

DATABASE_URL="postgresql://myapp:myapp@localhost:5432/myapp?schema=public"
# Optional direct connection URL for Prisma CLI operations.
DIRECT_URL="postgresql://myapp:myapp@localhost:5432/myapp?schema=public"
# Comma-separated emails that should always be treated as ADMIN on register/login.
BOOTSTRAP_ADMIN_EMAILS="admin@demo.com"
